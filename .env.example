# Graph Database (Neo4j or Memgraph)
# Use 'mock://' for in-memory testing without a database
GRAPH_DB_URI=mock://
GRAPH_DB_USERNAME=
GRAPH_DB_PASSWORD=

# Alternative: Use in-memory mock database
# Set USE_MOCK_DB=true to force mock mode
USE_MOCK_DB=true

# LLM (Tinfoil / Confidential AI)
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Server
PORT=3000
HOST=localhost

# Paths
WORKSPACE_ROOT=/home/ubuntu
MARKDOWN_NODES_DIR=./markdown-nodes

# Security
ENABLE_ATTESTATION=true
TEE_ENABLED=true
