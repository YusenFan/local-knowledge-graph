{
  "name": "local-knowledge-graph",
  "version": "0.1.0",
  "description": "A graph-first local knowledge system with LLM-powered structural understanding",
  "main": "dist/src/backend/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsc && node dist/src/backend/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "tsc && cd frontend && npm run build",
    "backend": "node dist/src/backend/index.js",
    "frontend": "cd frontend && npm run start",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "knowledge-graph",
    "local-ai",
    "privacy",
    "confidential-computing",
    "graph-database",
    "typescript"
  ],
  "author": "Yusen",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.2.0",
    "neo4j-driver": "^5.26.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14"
  }
}
